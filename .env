# =============================================================================
# SMARTPROIA ULTRA AI - VARIABLES DE ENTORNO v4.0
# =============================================================================

# SERVIDOR
NODE_ENV=production
PORT=3001

# BASE DE DATOS (PostgreSQL) - OBLIGATORIO
# Railway te dará esta URL automáticamente cuando agregues PostgreSQL
DATABASE_URL=postgresql://usuario:password@host:puerto/database?ssl=true

# AUTENTICACIÓN - OBLIGATORIO
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu_jwt_secret_super_seguro_de_64_caracteres_minimo_aqui

# ANTHROPIC CLAUDE AI - OBLIGATORIO para IA Ultra
# Obtener en: https://console.anthropic.com/
# Plan recomendado: Pro ($20/mes) para mejor rendimiento
ANTHROPIC_API_KEY=sk-ant-api-key-aqui

# ALPHA VANTAGE - RECOMENDADO para datos reales de mercado
# Obtener GRATIS en: https://www.alphavantage.co/
# Plan gratuito: 5 calls/min, 500 calls/día
ALPHA_VANTAGE_API_KEY=tu_alpha_vantage_api_key

# COINGECKO - OPCIONAL para datos crypto premium
# API gratuita disponible, no requiere key para uso básico
COINGECKO_API_KEY=tu_coingecko_api_key_opcional

# CONFIGURACIÓN DE APLICACIÓN
APP_NAME=SmartProIA Ultra AI
APP_URL=https://smartproia.com
FRONTEND_URL=https://smartproia.com

# LÍMITES DE RATE LIMITING
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# CONFIGURACIÓN AVANZADA - OPCIONAL
LOG_LEVEL=info
MAX_REQUEST_SIZE=10mb
SESSION_TIMEOUT=24h
CORS_ORIGIN=https://smartproia.com,https://www.smartproia.com

# CONFIGURACIÓN DE IA
AI_MODEL_TEMPERATURE=0.3
AI_MAX_TOKENS_FREE=300
AI_MAX_TOKENS_PRO=600
AI_MAX_TOKENS_ENTERPRISE=1200

# CONFIGURACIÓN DE DATOS DE MERCADO
MARKET_UPDATE_INTERVAL=120000
CACHE_TTL=180000
DATA_RETENTION_DAYS=90

# CONFIGURACIÓN DE SEGURIDAD
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=15

# =============================================================================
# INSTRUCCIONES DE CONFIGURACIÓN:
# =============================================================================
# 
# 1. OBLIGATORIOS para funcionamiento básico:
#    - DATABASE_URL (PostgreSQL - Railway lo configura automáticamente)
#    - JWT_SECRET (generar uno seguro con el comando de arriba)
#
# 2. OBLIGATORIOS para IA Ultra:
#    - ANTHROPIC_API_KEY (Claude AI)
#
# 3. RECOMENDADOS para datos reales:
#    - ALPHA_VANTAGE_API_KEY (datos de acciones)
#
# 4. Para Railway deployment:
#    - Todas las variables se configuran en el dashboard de Railway
#    - NO subir este archivo a GitHub con datos reales
#    - Usar este archivo solo como template
#
# 5. Generar JWT_SECRET seguro:
#    node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# =============================================================================
